<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
xmlns:android="http://schemas.android.com/apk/res/android"
android:id="@+id/main"
android:layout_width="match_parent"
android:layout_height="match_parent">

<!-- Background image -->
<ImageView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:src="@drawable/bg1"
    android:scaleType="centerCrop" />

<!-- Dark overlay -->
<View
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#66000000" />

<!-- Top bar -->
<LinearLayout
    android:id="@+id/topBar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical">

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/app_name"
        android:textSize="35sp"
        android:textColor="#FFFFFF" />

    <TextView
        android:id="@+id/tvStreak"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔥 5"
        android:textSize="18sp"
        android:textColor="#FFFFFF" />

</LinearLayout>

<!-- Center card -->
<LinearLayout
    android:id="@+id/groupCard"
    android:layout_width="270dp"
    android:layout_height="wrap_content"
    android:layout_centerInParent="true"
    android:background="@drawable/round_bg_card"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Group"
        android:textColor="#2D1B4E"
        android:textSize="28sp" />

    <TextView
        android:id="@+id/tvGroupName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Punk Vibes 💜"
        android:textColor="#2D1B4E"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btnOpenChat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:backgroundTint="#6A0DAD"
        android:text="Open Chat"
        android:textColor="#FFFFFF" />

</LinearLayout>

<!-- Bottom navigation -->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="60dp"
    android:layout_alignParentBottom="true"
    android:orientation="horizontal"
    android:background="#CC2D1B4E">

    <TextView
        android:id="@+id/navChat"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:text="💬 Chat"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/navPhotos"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:text="📷 Photos"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/navCanvas"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:text="🎨 Canvas"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/navLinks"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:text="🔗 Links"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

</LinearLayout>

</RelativeLayout>